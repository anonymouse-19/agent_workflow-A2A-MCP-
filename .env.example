

GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

ORCHESTRATOR_URL=http://localhost:8000
READER_AGENT_URL=http://localhost:8001
ANALYZER_AGENT_URL=http://localhost:8002
SUMMARIZER_AGENT_URL=http://localhost:8003
MCP_SERVER_URL=http://localhost:8004

AGENT_URLS=http://localhost:8001,http://localhost:8002,http://localhost:8003

REDIS_URL=redis://localhost:6379/0

ORCHESTRATOR_PORT=8000
READER_PORT=8001
ANALYZER_PORT=8002
SUMMARIZER_PORT=8003
MCP_PORT=8004

# Required: Groq API key (add your actual key here)
GROQ_API_KEY=your_groq_api_key_here

# Groq models (defaults shown)
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama3-8b-8192

# Service URLs (Docker overrides these via service names)
ORCHESTRATOR_URL=http://localhost:8000
READER_AGENT_URL=http://localhost:8001
ANALYZER_AGENT_URL=http://localhost:8002
SUMMARIZER_AGENT_URL=http://localhost:8003
MCP_SERVER_URL=http://localhost:8004

# Comma-separated agent URLs for discovery
AGENT_URLS=http://localhost:8001,http://localhost:8002,http://localhost:8003

# Redis
REDIS_URL=redis://localhost:6379/0

# Ports
ORCHESTRATOR_PORT=8000
READER_PORT=8001
ANALYZER_PORT=8002
SUMMARIZER_PORT=8003
MCP_PORT=8004

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
